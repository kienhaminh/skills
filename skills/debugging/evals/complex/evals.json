{
  "version": 1,
  "skill": "debugging",
  "method": "Independent read-only static-analysis runs over isolated fixtures. Natural user prompts do not encode the skill workflow. Same prompt with and without the skill; no rubric or expected answer is shown. gpt-5.6-terra low and medium reasoning.",
  "max_output_words": 200,
  "pass_threshold": 8,
  "maximum_per_case": 10,
  "models": [
    {"model": "gpt-5.6-terra", "reasoning_effort": "low"},
    {"model": "gpt-5.6-terra", "reasoning_effort": "medium"}
  ],
  "cases": [
    {
      "id": "lost-update",
      "prompt": "Treat FIXTURE as the project root. The counter anomaly is too expensive to reproduce, so investigate the incident from the current code without running anything. Diagnose the root cause and explain your confidence. Do not propose a fix or edit the fixture. FIXTURE=<debugging-skill-dir>/evals/complex/fixtures/lost-update",
