        {"id":"alternatives","points":1,"groups":[["alternative", "repository error", "database error", "audit failure"]]},
        {"id":"uncertainty","points":1,"groups":[["confidence"],["unverified", "would confirm", "confirmation.*require", "evidence.*needed", "not reproduced", "analysis.derived", "runtime.confirmed", "to confirm"]]},
        {"id":"diagnose-only","points":1,"forbidden":["you should", "recommend", "to fix", "use an atomic", "add a lock"]}
      ]
    },
