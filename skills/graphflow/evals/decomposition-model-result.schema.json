{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cases"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "cases": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "action", "reason", "proposal"],
        "properties": {
          "case_id": {"type": "string", "enum": ["structural-execute", "semantic-ambiguity", "integration-redesign"]},
          "action": {"type": "string", "enum": ["decompose", "rebase"]},
          "reason": {"type": "string", "minLength": 1},
          "proposal": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["schema_version", "contract_change", "reason_class", "reason", "measure", "terminal_child", "children"],
            "properties": {
              "schema_version": {"type": "integer", "const": 1},
              "contract_change": {"type": "string", "const": "structural"},
              "reason_class": {"type": "string", "enum": ["complexity", "context", "hidden_dependency"]},
              "reason": {"type": "string"},
              "measure": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "parent", "children"],
                "properties": {
                  "name": {"type": "string"},
                  "parent": {"type": "integer"},
                  "children": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["key", "value"],
                      "properties": {
                        "key": {"type": "string"},
                        "value": {"type": "integer"}
                      }
                    }
                  }
                }
              },
              "terminal_child": {"type": "string"},
              "children": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["key", "title", "outcome", "operations", "methods", "skills", "depends_on", "scope", "consumes", "outputs", "acceptance", "acceptance_checks", "budget_tokens"],
                  "properties": {
                    "key": {"type": "string"},
                    "title": {"type": "string"},
                    "outcome": {"type": "string"},
                    "operations": {"type": "array", "items": {"type": "string"}},
                    "methods": {"type": "array", "items": {"type": "string"}},
                    "skills": {"type": "array", "items": {"type": "string"}},
                    "depends_on": {"type": "array", "items": {"type": "string"}},
                    "scope": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["read", "write", "artifacts", "decisions", "forbidden"],
                      "properties": {
                        "read": {"type": "array", "items": {"type": "string"}},
                        "write": {"type": "array", "items": {"type": "string"}},
                        "artifacts": {"type": "array", "items": {"type": "string"}},
                        "decisions": {"type": "array", "items": {"type": "string"}},
                        "forbidden": {"type": "array", "items": {"type": "string"}}
                      }
                    },
                    "consumes": {"type": "array", "items": {"type": "string"}},
                    "outputs": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["id", "description", "artifact"],
                        "properties": {
                          "id": {"type": "string"},
                          "description": {"type": "string"},
                          "artifact": {"type": ["string", "null"]}
                        }
                      }
                    },
                    "acceptance": {"type": "array", "items": {"type": "string"}},
                    "acceptance_checks": {"type": "array", "items": {"type": "string"}},
                    "budget_tokens": {"type": "integer"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
