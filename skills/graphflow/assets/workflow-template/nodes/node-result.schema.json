{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workflow_id", "node_id", "attempt", "idempotency_key", "status", "summary", "outputs", "evidence", "memory_delta", "request", "decomposition", "usage"],
  "properties": {
    "schema_version": {"type": "integer", "const": 2},
    "workflow_id": {"type": "string"},
    "node_id": {"type": "string"},
    "attempt": {"type": "integer", "minimum": 0},
    "idempotency_key": {"type": "string"},
    "status": {"type": "string", "enum": ["succeeded", "decompose", "waiting_user", "waiting_approval", "waiting_external", "blocked", "failed"]},
    "summary": {"type": "string"},
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "artifact", "digest"],
        "properties": {"id": {"type": "string"}, "artifact": {"type": "string"}, "digest": {"type": "string"}}
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "check", "artifact", "digest", "exit_code", "note"],
        "properties": {
          "kind": {"type": ["string", "null"]},
          "check": {"type": ["string", "null"]},
          "artifact": {"type": ["string", "null"]},
          "digest": {"type": ["string", "null"]},
          "exit_code": {"type": ["integer", "null"]},
          "note": {"type": ["string", "null"]}
        }
      }
    },
    "memory_delta": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["schema_version", "base_revision", "author_node", "add", "supersede", "resolve"],
      "properties": {
        "schema_version": {"type": "integer", "const": 1},
        "base_revision": {"type": "integer", "minimum": 0},
        "author_node": {"type": "string"},
        "add": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "namespace", "summary", "status", "evidence_state", "confidence", "owner_node", "requirement_ids", "relevant_nodes", "artifact_refs", "pivotal", "supersedes"],
            "properties": {
              "id": {"type": "string"},
              "kind": {"type": "string", "enum": ["fact", "decision", "risk", "question", "learning", "handoff"]},
              "namespace": {"type": "string"},
              "summary": {"type": "string"},
              "status": {"type": "string", "const": "active"},
              "evidence_state": {"type": "string", "enum": ["verified", "observed", "inferred", "unverified"]},
              "confidence": {"type": "string", "enum": ["high", "medium", "low", "none"]},
              "owner_node": {"type": "string"},
              "requirement_ids": {"type": "array", "items": {"type": "string"}},
              "relevant_nodes": {"type": "array", "items": {"type": "string"}},
              "artifact_refs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path", "digest"],
                  "properties": {"path": {"type": "string"}, "digest": {"type": "string"}}
                }
              },
              "pivotal": {"type": "boolean"},
              "supersedes": {"type": ["string", "null"]}
            }
          }
        },
        "supersede": {"type": "array", "items": {"type": "string"}},
        "resolve": {"type": "array", "items": {"type": "string"}}
      }
    },
    "request": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["request_id", "digest", "question", "alternatives", "risks", "triage"],
      "properties": {
        "request_id": {"type": "string"},
        "digest": {"type": "string"},
        "question": {"type": "string"},
        "alternatives": {"type": "array", "items": {"type": "string"}},
        "risks": {"type": "array", "items": {"type": "string"}},
        "triage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["blocking_scope", "impacts", "affected_nodes", "no_safe_default_reason", "resolution_mode", "request_graph_digest", "authority_capabilities"],
          "properties": {
            "blocking_scope": {"type": "string", "enum": ["branch", "workflow"]},
            "impacts": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "enum": ["objective", "acceptance", "scope", "authority", "intent_baseline", "verification_oracle", "cost_risk", "irreversible_action"]}
            },
            "affected_nodes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "no_safe_default_reason": {"type": "string", "minLength": 1},
            "resolution_mode": {"type": "string", "enum": ["resume", "rebase"]},
            "request_graph_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "authority_capabilities": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string", "enum": ["local_write", "commit", "push", "pull_request", "merge", "deploy", "destructive", "network", "credentials"]}
            }
          }
        }
      }
    },
    "decomposition": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["schema_version", "contract_change", "reason_class", "reason", "measure", "terminal_child", "children"],
      "properties": {
        "schema_version": {"type": "integer", "const": 1},
        "contract_change": {"type": "string", "const": "structural"},
        "reason_class": {"type": "string", "enum": ["complexity", "context", "hidden_dependency"]},
        "reason": {"type": "string", "minLength": 1},
        "measure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "parent", "children"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "parent": {"type": "integer", "minimum": 2},
            "children": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["key", "value"],
                "properties": {
                  "key": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
                  "value": {"type": "integer", "minimum": 1}
                }
              }
            }
          }
        },
        "terminal_child": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "children": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "title", "outcome", "operations", "methods", "skills", "depends_on", "scope", "consumes", "outputs", "acceptance", "acceptance_checks", "budget_tokens"],
            "properties": {
              "key": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
              "title": {"type": "string", "minLength": 1},
              "outcome": {"type": "string", "minLength": 1},
              "operations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
              "methods": {"type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": {"type": "string"}},
              "skills": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
              "depends_on": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}},
              "scope": {
                "type": "object",
                "additionalProperties": false,
                "required": ["read", "write", "artifacts", "decisions", "forbidden"],
                "properties": {
                  "read": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
                  "write": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
                  "artifacts": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
                  "decisions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
                  "forbidden": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
                }
              },
              "consumes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
              "outputs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "description", "artifact"],
                  "properties": {
                    "id": {"type": "string"},
                    "description": {"type": "string"},
                    "artifact": {"type": ["string", "null"]}
                  }
                }
              },
              "acceptance": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "acceptance_checks": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
              "budget_tokens": {"type": "integer", "minimum": 1}
            }
          }
        }
      }
    },
    "verification": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["schema_version", "outcome", "challenge_classes", "claims", "limitations"],
      "properties": {
        "schema_version": {"type": "integer", "const": 1},
        "outcome": {"type": "string", "enum": ["pass", "fail"]},
        "challenge_classes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "claims": {"type": "array", "items": {"type": "object"}},
        "limitations": {"type": "array", "items": {"type": "string"}}
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens"],
      "properties": {
        "input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "output_tokens": {"type": ["integer", "null"], "minimum": 0}
      }
    }
  }
}
